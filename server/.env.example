# Postgres connection string for Vercel/Neon
DATABASE_URL=postgres://user:password@host/dbname

# NovelAI API Token (from your NovelAI account settings)
NOVELAI_TOKEN=your_novelai_api_token_here
# Optional alias if you already use this key
NOVELAI_API_TOKEN=your_novelai_api_token_here

# JWT Secret for authentication
JWT_SECRET=change_this_to_a_random_secret_key

# Admin account credentials (created on first run)
ADMIN_EMAIL=admin@illustconverter.com
ADMIN_PASSWORD=admin123456

# Demo user credentials (created on first run)
DEMO_EMAIL=demo.user@illustconverter.com
DEMO_PASSWORD=user123456
DEMO_USERNAME=Demo User
DEMO_CREDITS=20

# Server port
PORT=3000

# Public app URL for Stripe redirects (optional in local dev)
APP_URL=http://localhost:3000
