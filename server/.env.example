# NovelAI API Token (from your NovelAI account settings)
NOVELAI_TOKEN=your_novelai_api_token_here

# JWT Secret for authentication
JWT_SECRET=change_this_to_a_random_secret_key

# Admin account credentials (created on first run)
ADMIN_EMAIL=admin@illustconverter.com
ADMIN_PASSWORD=admin123456

# Server port
PORT=3000
